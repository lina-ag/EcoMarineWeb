{{ form_start(form, {'attr': {'class': 'activity-form'}}) }}
    <div class="form-grid">
        <div class="form-group-settings">
            {{ form_label(form.nom_activite, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.nom_activite, {'attr': {'class': 'form-input', 'placeholder': "Ex. Nettoyage de plage"}}) }}
            {{ form_errors(form.nom_activite) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.date_activite, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.date_activite, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.date_activite) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.capacite, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.capacite, {'attr': {'class': 'form-input', 'min': 1, 'max': 500}}) }}
            {{ form_errors(form.capacite) }}
        </div>

        <div class="form-group-settings full-width">
            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-input', 'rows': 5, 'placeholder': 'Décrivez l’activité'}}) }}
            {{ form_errors(form.description) }}
        </div>
    </div>

    <div class="btn-group">
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
        <a href="{{ path('app_activite_ecologique_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}

