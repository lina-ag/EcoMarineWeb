{% extends 'base_admin.html.twig' %}

{% block page_title %}Détail activité écologique{% endblock %}
{% block navbar_title %}Détail activité écologique{% endblock %}

{% block admin_content %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">{{ activite_ecologique.nomActivite }}</h2>
                <p class="card-subtitle">Informations détaillées sur l'activité</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr>
                        <th>Id activité</th>
                        <td>{{ activite_ecologique.idActivite }}</td>
                    </tr>
                    <tr>
                        <th>Nom activité</th>
                        <td>{{ activite_ecologique.nomActivite }}</td>
                    </tr>
                    <tr>
                        <th>Date activité</th>
                        <td>{{ activite_ecologique.dateActivite ? activite_ecologique.dateActivite|date('Y-m-d') : '' }}</td>
                    </tr>
                    <tr>
                        <th>Capacité</th>
                        <td>{{ activite_ecologique.capacite }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>{{ activite_ecologique.description }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_activite_ecologique_index') }}" class="btn btn-secondary">Retour à la liste</a>
            <a href="{{ path('app_activite_ecologique_edit', {'id_activite': activite_ecologique.id_activite}) }}" class="btn btn-primary">Modifier</a>
        </div>

        {{ include('activite_ecologique/_delete_form.html.twig') }}
    </section>
{% endblock %}
