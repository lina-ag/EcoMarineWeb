{% extends 'base.html.twig' %}

{% block title %}ActiviteEcologique index{% endblock %}

{% block body %}
    <h1>ActiviteEcologique index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id_activite</th>
                <th>Nom_activite</th>
                <th>Date_activite</th>
                <th>Capacite</th>
                <th>Description</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for activite_ecologique in activite_ecologiques %}
            <tr>
                <td>{{ activite_ecologique.idActivite }}</td>
                <td>{{ activite_ecologique.nomActivite }}</td>
                <td>{{ activite_ecologique.dateActivite ? activite_ecologique.dateActivite|date('Y-m-d') : '' }}</td>
                <td>{{ activite_ecologique.capacite }}</td>
                <td>{{ activite_ecologique.description }}</td>
                <td>
                    <a href="{{ path('app_activite_ecologique_show', {'id_activite': activite_ecologique.id_activite}) }}">show</a>
                    <a href="{{ path('app_activite_ecologique_edit', {'id_activite': activite_ecologique.id_activite}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_activite_ecologique_new') }}">Create new</a>
{% endblock %}
