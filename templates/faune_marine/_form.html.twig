{{ form_start(form) }}
    <div class="form-grid">
        <div class="form-group-settings">
            {{ form_label(form.espece, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.espece, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.espece) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.etat, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.etat, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.etat) }}
        </div>

        <div class="form-group-settings full-width">
            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-input', 'rows': 5}}) }}
            {{ form_errors(form.description) }}
        </div>
    </div>

    <div class="btn-group">
        <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
        <a href="{{ path('app_faune_marine_index') }}" class="btn btn-secondary">back to list</a>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}
