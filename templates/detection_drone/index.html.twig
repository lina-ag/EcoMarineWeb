{% extends 'base.html.twig' %}

{% block title %}DetectionDrone index{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Detections drone</h2>
                <p class="card-subtitle">Analyse des detections pendant les missions.</p>
            </div>
            <a href="{{ path('app_detection_drone_new') }}" class="btn btn-primary">Create new</a>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Mission</th>
                        <th>Espece</th>
                        <th>Individus</th>
                        <th>Latitude</th>
                        <th>Longitude</th>
                        <th>Confiance IA</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for detection_drone in detection_drones %}
                    <tr>
                        <td>{{ detection_drone.idDetection }}</td>
                        <td>{{ detection_drone.idMission }}</td>
                        <td>{{ detection_drone.espece }}</td>
                        <td>{{ detection_drone.nombreIndividus }}</td>
                        <td>{{ detection_drone.latitude }}</td>
                        <td>{{ detection_drone.longitude }}</td>
                        <td>{{ detection_drone.confianceIa }}</td>
                        <td>
                            <a href="{{ path('app_detection_drone_show', {'id_detection': detection_drone.id_detection}) }}" class="btn btn-secondary">show</a>
                            <a href="{{ path('app_detection_drone_edit', {'id_detection': detection_drone.id_detection}) }}" class="btn btn-primary">edit</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8">no records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
