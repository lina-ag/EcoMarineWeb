{% extends 'base.html.twig' %}

{% block title %}DetectionDrone{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Detection #{{ detection_drone.idDetection }}</h2>
                <p class="card-subtitle">Details de la detection IA.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ detection_drone.idDetection }}</td></tr>
                    <tr><th>Mission</th><td>{{ detection_drone.idMission }}</td></tr>
                    <tr><th>Espece</th><td>{{ detection_drone.espece }}</td></tr>
                    <tr><th>Individus</th><td>{{ detection_drone.nombreIndividus }}</td></tr>
                    <tr><th>Latitude</th><td>{{ detection_drone.latitude }}</td></tr>
                    <tr><th>Longitude</th><td>{{ detection_drone.longitude }}</td></tr>
                    <tr><th>Comportement</th><td>{{ detection_drone.comportement }}</td></tr>
                    <tr><th>Confiance IA</th><td>{{ detection_drone.confianceIa }}</td></tr>
                    <tr><th>Image</th><td>{{ detection_drone.imagePath }}</td></tr>
                    <tr><th>Timestamp</th><td>{{ detection_drone.timestamp }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_detection_drone_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_detection_drone_edit', {'id_detection': detection_drone.id_detection}) }}" class="btn btn-primary">edit</a>
            {{ include('detection_drone/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
