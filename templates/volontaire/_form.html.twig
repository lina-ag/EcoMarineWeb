{{ form_start(form) }}
    <div class="form-grid">
        <div class="form-group-settings">
            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.contact, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.contact, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.contact) }}
        </div>

        <div class="form-group-settings full-width">
            {{ form_label(form.id_action, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.id_action, {'attr': {'class': 'form-input', 'placeholder': 'Identifiant de l action'}}) }}
            {{ form_errors(form.id_action) }}
        </div>
    </div>

    <div class="btn-group">
        <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
        <a href="{{ path('app_volontaire_index') }}" class="btn btn-secondary">back to list</a>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}
