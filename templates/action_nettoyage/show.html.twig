{% extends 'base.html.twig' %}

{% block title %}ActionNettoyage{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Action #{{ action_nettoyage.idAction }}</h2>
                <p class="card-subtitle">Details de l action de nettoyage.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ action_nettoyage.idAction }}</td></tr>
                    <tr><th>Date</th><td>{{ action_nettoyage.dateAction }}</td></tr>
                    <tr><th>Lieu</th><td>{{ action_nettoyage.lieu }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_action_nettoyage_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_action_nettoyage_edit', {'id_action': action_nettoyage.id_action}) }}" class="btn btn-primary">edit</a>
            {{ include('action_nettoyage/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
