{% extends 'base.html.twig' %}

{% block title %}Détail réservation{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Réservation de {{ reservation.nom }}</h2>
                <p class="card-subtitle">Consultation des informations de réservation.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr>
                        <th>Id réservation</th>
                        <td>{{ reservation.idReservation }}</td>
                    </tr>
                    <tr>
                        <th>Nom</th>
                        <td>{{ reservation.nom }}</td>
                    </tr>
                    <tr>
                        <th>Date réservation</th>
                        <td>{{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d') : '' }}</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>{{ reservation.email }}</td>
                    </tr>
                    <tr>
                        <th>Nombre personnes</th>
                        <td>{{ reservation.nombrePersonnes }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_reservation_index') }}" class="btn btn-secondary">Retour à la liste</a>
            <a href="{{ path('app_reservation_edit', {'id_reservation': reservation.id_reservation}) }}" class="btn btn-primary">Modifier</a>
        </div>

        {{ include('reservation/_delete_form.html.twig') }}
    </section>
{% endblock %}
