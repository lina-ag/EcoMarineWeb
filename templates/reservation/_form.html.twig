{{ form_start(form, {'attr': {'class': 'reservation-form'}}) }}
    <div class="form-grid">
        <div class="form-group-settings">
            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-input', 'placeholder': 'Nom complet'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.date_reservation, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.date_reservation, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.date_reservation) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'form-input', 'placeholder': 'email@exemple.com'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.nombre_personnes, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.nombre_personnes, {'attr': {'class': 'form-input', 'min': 1, 'max': 50}}) }}
            {{ form_errors(form.nombre_personnes) }}
        </div>

        <div class="form-group-settings full-width">
            {{ form_label(form.activiteEcologique, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.activiteEcologique, {'attr': {'class': 'settings-select'}}) }}
            {{ form_errors(form.activiteEcologique) }}
        </div>
    </div>

    <div class="btn-group">
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
        <a href="{{ path('app_reservation_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}
