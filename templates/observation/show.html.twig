{% extends 'base.html.twig' %}

{% block title %}Observation{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Observation #{{ observation.idObservation }}</h2>
                <p class="card-subtitle">Details de l observation.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ observation.idObservation }}</td></tr>
                    <tr><th>Date</th><td>{{ observation.dateObservation ? observation.dateObservation|date('Y-m-d') : '' }}</td></tr>
                    <tr><th>Temperature</th><td>{{ observation.temperature }}</td></tr>
                    <tr><th>Meteo</th><td>{{ observation.meteo }}</td></tr>
                    <tr><th>Id animal</th><td>{{ observation.idAnimal }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_observation_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_observation_edit', {'id_observation': observation.id_observation}) }}" class="btn btn-primary">edit</a>
            {{ include('observation/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
