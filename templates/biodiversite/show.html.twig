{% extends 'base.html.twig' %}

{% block title %}Biodiversite{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Biodiversite #{{ biodiversite.id }}</h2>
                <p class="card-subtitle">Details de l observation biodiversite.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ biodiversite.id }}</td></tr>
                    <tr><th>Espece</th><td>{{ biodiversite.espece }}</td></tr>
                    <tr><th>Zone</th><td>{{ biodiversite.zone }}</td></tr>
                    <tr><th>Nombre</th><td>{{ biodiversite.nombre }}</td></tr>
                    <tr><th>Date</th><td>{{ biodiversite.date }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_biodiversite_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_biodiversite_edit', {'id': biodiversite.id}) }}" class="btn btn-primary">edit</a>
            {{ include('biodiversite/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
