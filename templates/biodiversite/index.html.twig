{% extends 'base.html.twig' %}

{% block title %}Biodiversite index{% endblock %}

{% block body %}
    <h1>Biodiversite index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Espece</th>
                <th>Zone</th>
                <th>Nombre</th>
                <th>Date</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for biodiversite in biodiversites %}
            <tr>
                <td>{{ biodiversite.id }}</td>
                <td>{{ biodiversite.espece }}</td>
                <td>{{ biodiversite.zone }}</td>
                <td>{{ biodiversite.nombre }}</td>
                <td>{{ biodiversite.date }}</td>
                <td>
                    <a href="{{ path('app_biodiversite_show', {'id': biodiversite.id}) }}">show</a>
                    <a href="{{ path('app_biodiversite_edit', {'id': biodiversite.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_biodiversite_new') }}">Create new</a>
{% endblock %}
