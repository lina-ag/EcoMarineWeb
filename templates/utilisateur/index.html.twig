{% extends 'base.html.twig' %}

{% block title %}Utilisateur index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .utilisateurs-compact .table-wrapper {
            overflow-x: auto;
            max-width: 980px;
            margin: 0 auto;
        }

        .utilisateurs-compact .data-table {
            width: 100%;
            table-layout: fixed;
        }

        .utilisateurs-compact .data-table th,
        .utilisateurs-compact .data-table td {
            padding: 0.75rem 0.9rem;
            vertical-align: middle;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .utilisateurs-compact .data-table th:last-child,
        .utilisateurs-compact .data-table td:last-child {
            width: 220px;
            overflow: visible;
            text-overflow: initial;
        }

        .utilisateurs-compact .data-table td:last-child {
            white-space: nowrap;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="glass-card utilisateurs-compact">
        <div class="card-header">
            <div>
                <h2 class="card-title">Utilisateurs</h2>
                <p class="card-subtitle">Gerer les comptes et informations des utilisateurs.</p>
            </div>
            <a href="{{ path('app_utilisateur_new') }}" class="btn btn-primary">Create new</a>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Nom</th>
                        <th>Prenom</th>
                        <th>Email</th>
                        <th>Telephone</th>
                        <th>Role</th>
                        <th>Date naissance</th>
                        <th>Face image</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for utilisateur in utilisateurs %}
                    <tr>
                        <td>{{ utilisateur.idUtilisateur }}</td>
                        <td>{{ utilisateur.nom }}</td>
                        <td>{{ utilisateur.prenom }}</td>
                        <td>{{ utilisateur.email }}</td>
                        <td>{{ utilisateur.telephone }}</td>
                        <td>{{ utilisateur.role }}</td>
                        <td>{{ utilisateur.dateNaissance ? utilisateur.dateNaissance|date('Y-m-d') : '' }}</td>
                        <td>{{ utilisateur.faceImage }}</td>
                        <td>{{ utilisateur.createdAt ? utilisateur.createdAt|date('Y-m-d H:i') : '' }}</td>
                        <td>
                            <a href="{{ path('app_utilisateur_show', {'id_utilisateur': utilisateur.id_utilisateur}) }}" class="btn btn-secondary">show</a>
                            <a href="{{ path('app_utilisateur_edit', {'id_utilisateur': utilisateur.id_utilisateur}) }}" class="btn btn-primary">edit</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="10">no records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
