{% extends 'base.html.twig' %}

{% block title %}Survzone index{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Surveillance des zones</h2>
                <p class="card-subtitle">Historique des observations et suivis des zones.</p>
            </div>
            <a href="{{ path('app_survzone_new') }}" class="btn btn-primary">Create new</a>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Date</th>
                        <th>Observation</th>
                        <th>Id zone</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for survzone in survzones %}
                    <tr>
                        <td>{{ survzone.idSurv }}</td>
                        <td>{{ survzone.dateSurv ? survzone.dateSurv|date('Y-m-d') : '' }}</td>
                        <td>{{ survzone.observation }}</td>
                        <td>{{ survzone.zone.nomZone  }}</td>
                        <td>
                            <a href="{{ path('app_survzone_show', {'idSurv': survzone.idSurv}) }}" class="btn btn-secondary">show</a>
                            <a href="{{ path('app_survzone_edit', {'idSurv': survzone.idSurv}) }}" class="btn btn-primary">edit</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">no records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
