{% extends 'base.html.twig' %}

{% block title %}Zonep{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Zone #{{ zonep.idZone }}</h2>
                <p class="card-subtitle">Details de la zone.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ zonep.idZone }}</td></tr>
                    <tr><th>Nom zone</th><td>{{ zonep.nomZone }}</td></tr>
                    <tr><th>Categorie</th><td>{{ zonep.categorieZone }}</td></tr>
                    <tr><th>Status</th><td>{{ zonep.status }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_zonep_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_zonep_edit', {'idZone': zonep.idZone}) }}" class="btn btn-primary">edit</a>
            {{ include('zonep/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
