<form method="post" action="{{ path('app_zonep_delete', {'idZone': zonep.idZone}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ zonep.idZone) }}">
    <button class="btn btn-secondary" type="submit">Delete</button>
</form>
