{% extends 'base.html.twig' %}

{% block title %}Dechet{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Dechet #{{ dechet.idDechet }}</h2>
                <p class="card-subtitle">Detail du dechet recense.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ dechet.idDechet }}</td></tr>
                    <tr><th>Type</th><td>{{ dechet.type }}</td></tr>
                    <tr><th>Quantite</th><td>{{ dechet.quantite }}</td></tr>
                    <tr><th>Zone</th><td>{{ dechet.zone }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_dechet_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_dechet_edit', {'id_dechet': dechet.id_dechet}) }}" class="btn btn-primary">edit</a>
            {{ include('dechet/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
