{{ form_start(form) }}
    <div class="form-grid">
        <div class="form-group-settings">
            {{ form_label(form.type, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.type, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.type) }}
        </div>

        <div class="form-group-settings">
            {{ form_label(form.quantite, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.quantite, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.quantite) }}
        </div>

        <div class="form-group-settings full-width">
            {{ form_label(form.zone, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.zone, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(form.zone) }}
        </div>
    </div>

    <div class="btn-group">
        <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
        <a href="{{ path('app_dechet_index') }}" class="btn btn-secondary">back to list</a>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}
