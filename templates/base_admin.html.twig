<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block page_title %}Dashboard{% endblock %} — EcoMarine Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets_admin/templatemo-glass-admin-style.css">
    <link rel="stylesheet" href="/assets/styles/app.css">

    {% block admin_stylesheets %}{% endblock %}
</head>
<body>

    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">

        {% include 'admin/partials/sidebar_admin.html.twig' %}

        <main class="main-content">

            {% include 'admin/partials/navbar_admin.html.twig' %}

            {% block admin_content %}{% endblock %}

        </main>
    </div>

    <button class="mobile-menu-toggle" id="mobileMenuToggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <footer class="site-footer">
        <p>EcoMarine &copy; {{ "now"|date("Y") }} — Plateforme d'écotourisme marin, Kuriat, Monastir</p>
    </footer>

    <script src="/assets_admin/templatemo-glass-admin-script.js"></script>
    {% block admin_javascripts %}{% endblock %}

</body>
</html>
