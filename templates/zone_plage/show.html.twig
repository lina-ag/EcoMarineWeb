{% extends 'base.html.twig' %}

{% block title %}ZonePlage{% endblock %}

{% block body %}
    <section class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Zone plage #{{ zone_plage.id_zone }}</h2>
                <p class="card-subtitle">Details de la zone de plage.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <tbody>
                    <tr><th>Id</th><td>{{ zone_plage.id_zone }}</td></tr>
                    <tr><th>Nom</th><td>{{ zone_plage.nom }}</td></tr>
                    <tr><th>Localisation</th><td>{{ zone_plage.localisation }}</td></tr>
                    <tr><th>Statut</th><td>{{ zone_plage.statut }}</td></tr>
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <a href="{{ path('app_zone_plage_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_zone_plage_edit', {'id_zone': zone_plage.id_zone}) }}" class="btn btn-primary">edit</a>
            {{ include('zone_plage/_delete_form.html.twig') }}
        </div>
    </section>
{% endblock %}
