{% extends 'base_admin.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block navbar_title %}Dashboard EcoMarine{% endblock %}

{% block admin_content %}

{# KPI Cards #}
<section class="stats-grid">

    <div class="glass-card glass-card-3d stat-card">
        <div class="stat-card-inner">
            <div class="stat-info">
                <h3>Réservations</h3>
                <div class="stat-value">248</div>
                <span class="stat-change positive">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                    +12.5% ce mois
                </span>
            </div>
            <div class="stat-icon cyan">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
        </div>
    </div>

    <div class="glass-card glass-card-3d stat-card">
        <div class="stat-card-inner">
            <div class="stat-info">
                <h3>Visiteurs</h3>
                <div class="stat-value">1 024</div>
                <span class="stat-change positive">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                    +8.2% ce mois
                </span>
            </div>
            <div class="stat-icon magenta">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
        </div>
    </div>

    <div class="glass-card glass-card-3d stat-card">
        <div class="stat-card-inner">
            <div class="stat-info">
                <h3>Activités</h3>
                <div class="stat-value">36</div>
                <span class="stat-change positive">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                    +3 nouvelles
                </span>
            </div>
            <div class="stat-icon purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--coral)" stroke-width="2">
                    <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 0v10l4 4"/>
                </svg>
            </div>
        </div>
    </div>

    <div class="glass-card glass-card-3d stat-card">
        <div class="stat-card-inner">
            <div class="stat-info">
                <h3>Espèces suivies</h3>
                <div class="stat-value">15</div>
                <span class="stat-change positive">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                    Kuriat protégée
                </span>
            </div>
            <div class="stat-icon success">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
        </div>
    </div>

</section>

{# Tableau des dernières réservations #}
<section class="content-grid">
    <div class="glass-card table-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Dernières Réservations</h2>
                <p class="card-subtitle">Activités récemment réservées</p>
            </div>
            <div class="card-actions">
                <button class="card-btn">Voir tout</button>
                <button class="card-btn">Exporter</button>
            </div>
        </div>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Visiteur</th>
                        <th>Activité</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Montant</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="table-user">
                                <div class="table-avatar" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald));">YB</div>
                                <div class="table-user-info">
                                    <span class="table-user-name">Yasmine Ben Ali</span>
                                    <span class="table-user-email">yasmine@email.com</span>
                                </div>
                            </div>
                        </td>
                        <td>Plongée à Kuriat</td>
                        <td>10 Avr 2026</td>
                        <td><span class="status-badge completed">Confirmée</span></td>
                        <td><span class="table-amount">120 TND</span></td>
                    </tr>
                    <tr>
                        <td>
                            <div class="table-user">
                                <div class="table-avatar" style="background: linear-gradient(135deg, var(--gold), var(--amber));">KM</div>
                                <div class="table-user-info">
                                    <span class="table-user-name">Karim Mansour</span>
                                    <span class="table-user-email">karim@email.com</span>
                                </div>
                            </div>
                        </td>
                        <td>Excursion en mer</td>
                        <td>11 Avr 2026</td>
                        <td><span class="status-badge processing">En attente</span></td>
                        <td><span class="table-amount">85 TND</span></td>
                    </tr>
                    <tr>
                        <td>
                            <div class="table-user">
                                <div class="table-avatar" style="background: linear-gradient(135deg, var(--coral), var(--gold));">SL</div>
                                <div class="table-user-info">
                                    <span class="table-user-name">Sofia Lacombe</span>
                                    <span class="table-user-email">sofia@email.com</span>
                                </div>
                            </div>
                        </td>
                        <td>Randonnée côtière</td>
                        <td>12 Avr 2026</td>
                        <td><span class="status-badge pending">Pending</span></td>
                        <td><span class="table-amount">50 TND</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# Activité récente #}
    <div class="glass-card activity-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Activité Récente</h2>
                <p class="card-subtitle">Dernières actions sur la plateforme</p>
            </div>
        </div>
        <div class="activity-list">
            <div class="activity-item">
                <div class="activity-avatar" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald));">YB</div>
                <div class="activity-content">
                    <p class="activity-text"><strong>Yasmine B.</strong> a réservé une plongée</p>
                    <span class="activity-time">Il y a 5 minutes</span>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-avatar" style="background: linear-gradient(135deg, var(--gold), var(--amber));">KM</div>
                <div class="activity-content">
                    <p class="activity-text"><strong>Karim M.</strong> a annulé une réservation</p>
                    <span class="activity-time">Il y a 30 minutes</span>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-avatar" style="background: linear-gradient(135deg, var(--success), var(--emerald));">AD</div>
                <div class="activity-content">
                    <p class="activity-text"><strong>Admin</strong> a ajouté une nouvelle activité</p>
                    <span class="activity-time">Il y a 1 heure</span>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-avatar" style="background: linear-gradient(135deg, var(--coral), var(--gold));">SL</div>
                <div class="activity-content">
                    <p class="activity-text"><strong>Sofia L.</strong> s'est inscrite</p>
                    <span class="activity-time">Il y a 2 heures</span>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}
